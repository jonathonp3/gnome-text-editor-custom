From 7b4cc5671cbe4b551b7fc4b079d8d9ed90cd9aff Mon Sep 17 00:00:00 2001
From: Maximiliano Sandoval <msandova@gnome.org>
Date: Wed, 18 Mar 2026 20:52:05 +0100
Subject: [PATCH 1/2] metainfo: Mark development releases as such

And replace dots with ~ in devel versions.

For better or worse, according to appstreamcli:

```
$ appstreamcli vercmp 50.rc 50.0
50.rc >> 50.0
```

See [1] for more details.

[1] https://www.freedesktop.org/software/appstream/docs/chap-AppStream-Misc.html#spec-vercmp-algorithm
---
 data/org.gnome.TextEditor.metainfo.xml.in.in | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/data/org.gnome.TextEditor.metainfo.xml.in.in b/data/org.gnome.TextEditor.metainfo.xml.in.in
index 89448b3..c042fa4 100644
--- a/data/org.gnome.TextEditor.metainfo.xml.in.in
+++ b/data/org.gnome.TextEditor.metainfo.xml.in.in
@@ -54,8 +54,8 @@
 
   <releases>
     <release version="50.0" date="2026-03-16"/>
-    <release version="50.rc" date="2025-02-23"/>
-    <release version="50.beta" date="2025-01-29"/>
+    <release version="50~rc" date="2025-02-23" type="development" />
+    <release version="50~beta" date="2025-01-29" type="development"/>
     <release version="49.0" date="2025-09-12"/>
   </releases>
 </component>
-- 
GitLab


